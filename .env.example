# Provider LLM actif : mistral | ollama | mock | auto
# auto = mistral si MISTRAL_API_KEY présent, sinon ollama, sinon mock
LLM_PROVIDER=mistral

# --- API Mistral (La Plateforme) ---
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# --- Ollama local (aucune clé requise) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
